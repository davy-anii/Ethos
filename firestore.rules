rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // ─── User Documents ───
    // Each user can only read/write their own user profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ─── Chat History ───
    // Each user can only read/write their own chat history
    match /users/{userId}/chatHistory/{chatSessionId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ─── Message Collection ───
    // Each user can only read/write messages in their own chat sessions
    match /users/{userId}/chatHistory/{chatSessionId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // ─── Deny all other access ───
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
